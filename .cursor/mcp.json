{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "cwd": "."
    },
    "doc-tools": {
      "command": "python3",
      "args": [
        ".cursor/mcps/doc-tools/server.py"
      ],
      "cwd": ".",
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
